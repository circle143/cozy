{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/cozy-reservation\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/gallery\\/ambiance\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/gallery\\/events\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/gallery\\/food\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/gallery\\/kitchen\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/gallery\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/menu\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/reservation\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}